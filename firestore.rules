rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserRole() {
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDoc) && 'role' in get(userDoc).data ? get(userDoc).data.role : 'none';
    }

    function isAdmin() {
      return isAuthenticated() && (
        ('email' in request.auth.token && request.auth.token.email == "michael.molzar@gmail.com" && 'email_verified' in request.auth.token && request.auth.token.email_verified == true) ||
        getUserRole() == 'admin'
      );
    }

    function isCoach() {
      return isAuthenticated() && (getUserRole() == 'coach' || isAdmin());
    }

    function isPlayerOrHigher() {
      return isAuthenticated() && (
        getUserRole() in ['player', 'coach', 'admin'] || 
        isAdmin()
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid.size() < 100 &&
             data.email is string && data.email.size() < 100 &&
             (!('name' in data) || (data.name is string && data.name.size() < 100)) &&
             data.role in ['admin', 'coach', 'player', 'guest'];
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (
        isAdmin() || 
        (isOwner(userId) && request.resource.data.role == 'guest')
      );
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (
        isAdmin() || 
        (isOwner(userId) && request.resource.data.role == resource.data.role && uidNotModified())
      );
      allow delete: if isAdmin();
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if isCoach();
    }

    match /coaches/{coachId} {
      allow read: if true;
      allow write: if isCoach();
    }

    match /playbook/{playbookId} {
      allow read: if isPlayerOrHigher();
      allow write: if isCoach();
    }

    match /trainingPlans/{planId} {
      allow read: if isPlayerOrHigher();
      allow write: if isCoach();
    }

    match /termine/{terminId} {
      allow read: if true;
      allow write: if isCoach();
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if isCoach();
    }

    match /campus/{articleId} {
      allow read: if true;
      allow write: if isCoach();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create: if isCoach();
      allow update: if isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']);
      allow delete: if isCoach();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /awayTrips/{tripId} {
      allow read: if isPlayerOrHigher();
      allow write: if isCoach();
    }
  }
}
